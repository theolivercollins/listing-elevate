# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# LLM
ANTHROPIC_API_KEY=sk-ant-xxx

# Gemini — "eyes" of the director (DA.1, 2026-04-21). Gemini 3 Flash does
# per-photo analysis and emits structured camera-state + motion_headroom.
# Director (still Claude Sonnet 4.6) respects motion_headroom as hard bans.
# Falls back to Claude photo analyzer if GEMINI_API_KEY is unset or the API
# errors. $0.50/M input, $3.00/M output tokens.
GEMINI_API_KEY=

# Embeddings (Prompt Lab learning loop — similarity retrieval across iterations)
# OpenAI text-embedding-3-small, 1536 dim, $0.02/M tokens
OPENAI_API_KEY=

# Video Generation Providers
RUNWAY_API_KEY=
KLING_API_KEY=
LUMA_API_KEY=

# Atlas Cloud unified video-gen provider. Primary integration as of
# Phase 2.7 (2026-04-19). ATLAS_VIDEO_MODEL selects which model the
# router submits to — kling-v3-pro (default, $0.095/5s) or wan-2.7
# ($0.10/5s, 2-15s flexible duration).
ATLASCLOUD_API_KEY=
ATLAS_VIDEO_MODEL=kling-v3-pro
# Seedance push-in SKU (v1.1 + customer pipeline). Defaults to the Atlas 2K
# upscaled variant for maximum quality. Override either for instant rollback
# to native 1080p without a deploy:
#   SEEDANCE_ATLAS_SLUG=bytedance/seedance-2.0/image-to-video   (standard model)
#   SEEDANCE_RESOLUTION=1080p                                   (1080p instead of 2k)
SEEDANCE_ATLAS_SLUG=
SEEDANCE_RESOLUTION=

# Video Assembly (Shotstack — fallback)
# SHOTSTACK_ENV=stage (sandbox, default) or production
# Use SHOTSTACK_API_KEY_STAGE for sandbox testing; SHOTSTACK_API_KEY for production
SHOTSTACK_ENV=stage
SHOTSTACK_API_KEY_STAGE=
SHOTSTACK_API_KEY=
# Shotstack bills per output-minute (rounded up). Default 20¢/min = Ingest plan rate.
# Override with 50 for the Create plan ($0.50/min).
# DEPRECATED: SHOTSTACK_CENTS_PER_RENDER (flat per-render) is honored as a back-compat
#   shim but logs a warning. Migrate to SHOTSTACK_CENTS_PER_MINUTE.
SHOTSTACK_CENTS_PER_MINUTE=20

# Video Assembly (Creatomate — preferred, better overlays/branding)
# If CREATOMATE_API_KEY is set, Creatomate is used as the primary assembly
# provider with Shotstack as fallback. See lib/providers/assembly-router.ts.
CREATOMATE_API_KEY=
# Public render token — used for client-side preview embeds only (safe to ship
# in front-end bundles). Never use for server renders; use CREATOMATE_API_KEY.
CREATOMATE_PUBLIC_TOKEN=
# Creatomate bills per credit (~28 credits/min at 1080p30). Default 76¢/min
# based on Essential plan ($54/mo for 2,000 credits).
CREATOMATE_CENTS_PER_MINUTE=76

# Per-package, per-duration Creatomate template IDs. When set, runAssembly
# skips the code-generated RenderScript path and renders via
# assembleFromTemplate. Each template is designed for one exact duration
# (15/30/60s), so we pick by package + selected_duration.
#
# Resolution priority (see lib/assembly/template-resolver.ts):
#   1. properties.template_id (per-order override)
#   2. CREATOMATE_TEMPLATE_ID_<PKG>_<DURATION>  (preferred)
#   3. CREATOMATE_TEMPLATE_ID_<PKG>             (legacy — only used when
#                                                selected_duration is NULL)
#   4. CREATOMATE_TEMPLATE_ID_DEFAULT           (legacy — same caveat)
#   5. null → fall back to code-generated render
#
# Safety: when selected_duration is set but no matching _<DURATION> template
# exists, the resolver returns null instead of rendering a wrong-length video
# from a different-duration template.
#
# Placeholder names the mapper writes are documented in
# lib/assembly/template-modifications.ts.
CREATOMATE_TEMPLATE_ID_JUST_LISTED_15=
CREATOMATE_TEMPLATE_ID_JUST_LISTED_30=
CREATOMATE_TEMPLATE_ID_JUST_LISTED_60=
CREATOMATE_TEMPLATE_ID_JUST_PENDED_15=
CREATOMATE_TEMPLATE_ID_JUST_PENDED_30=
CREATOMATE_TEMPLATE_ID_JUST_PENDED_60=
CREATOMATE_TEMPLATE_ID_JUST_CLOSED_15=
CREATOMATE_TEMPLATE_ID_JUST_CLOSED_30=
CREATOMATE_TEMPLATE_ID_JUST_CLOSED_60=
CREATOMATE_TEMPLATE_ID_LIFE_CYCLE_15=
CREATOMATE_TEMPLATE_ID_LIFE_CYCLE_30=
CREATOMATE_TEMPLATE_ID_LIFE_CYCLE_60=
# Vertical (9:16) variants — append _VERTICAL to any duration-suffixed var.
# When unset, the pipeline skips the 9:16 render entirely (we aren't
# offering vertical yet). Vertical never falls back to legacy un-suffixed
# vars — that would silently render at 16:9.
CREATOMATE_TEMPLATE_ID_JUST_LISTED_15_VERTICAL=
CREATOMATE_TEMPLATE_ID_JUST_LISTED_30_VERTICAL=
CREATOMATE_TEMPLATE_ID_JUST_LISTED_60_VERTICAL=
# Legacy un-suffixed vars — kept for back-compat. Honored only when
# selected_duration is NULL on the property (older orders).
CREATOMATE_TEMPLATE_ID_JUST_LISTED=
CREATOMATE_TEMPLATE_ID_JUST_PENDED=
CREATOMATE_TEMPLATE_ID_JUST_CLOSED=
CREATOMATE_TEMPLATE_ID_LIFE_CYCLE=
CREATOMATE_TEMPLATE_ID_DEFAULT=

# Assembly provider override. Optional. When set to "creatomate" or "shotstack",
# forces runAssembly to use that provider regardless of the default Creatomate-
# first priority. Useful for A/B testing both providers in parallel.
ASSEMBLY_PROVIDER=

# Notifications
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM_EMAIL=noreply@reelready.com
WEBHOOK_SECRET=

# Stripe — get test keys from dashboard.stripe.com/test/apikeys.
# Webhook secret: create a webhook endpoint at
#   dashboard.stripe.com/test/webhooks
# pointing to /api/stripe/webhook and listening on:
#   checkout.session.completed
#   checkout.session.expired
#   payment_intent.payment_failed
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# AI Voiceover (feat/voiceover-pipeline, 2026-05-15)
# ElevenLabs TTS — defaults to eleven_v3 (most human; supports audio tags).
ELEVENLABS_API_KEY=
# Override the TTS model (e.g. eleven_multilingual_v2) for instant rollback
# without a deploy if a voice 404s on v3 or v3 latency hurts the preview UX.
ELEVENLABS_MODEL_ID=
# Default narrator voice for the pipeline auto-trigger when the order didn't
# pick one. Must be a valid id from lib/voiceover/voices.ts. Default: Amanda.
ELEVENLABS_DEFAULT_VOICE_ID=
# Apify — scrapes Compass listing descriptions (headless Puppeteer)
# ~$0.005/page crawl, billed via actor runs
APIFY_API_TOKEN=

# Pipeline Config
MAX_RETRIES_PER_CLIP=2
QC_CONFIDENCE_THRESHOLD=0.75
QC_AUTO_APPROVE_THRESHOLD=0.95
DEFAULT_CLIP_DURATION=3.5
TRANSITION_DURATION=0.4
