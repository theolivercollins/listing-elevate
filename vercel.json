{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://placehold.co https://maps.googleapis.com https://maps.gstatic.com https://storage.googleapis.com https://*.b-cdn.net; media-src 'self' https://*.b-cdn.net; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://maps.googleapis.com; frame-src https://iframe.mediadelivery.net; frame-ancestors 'none'; object-src 'none'" }
      ]
    },
    {
      "source": "/preview/:token/embed",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://images.unsplash.com https://placehold.co https://maps.googleapis.com https://maps.gstatic.com https://storage.googleapis.com https://*.b-cdn.net; media-src 'self' https://*.b-cdn.net; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://maps.googleapis.com; frame-src https://iframe.mediadelivery.net; frame-ancestors *; object-src 'none'" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/poll-scenes", "schedule": "* * * * *" },
    { "path": "/api/cron/poll-lab-renders", "schedule": "* * * * *" },
    { "path": "/api/cron/poll-listing-iterations", "schedule": "* * * * *" },
    { "path": "/api/cron/poll-listing-lifecycle", "schedule": "* * * * *" },
    { "path": "/api/cron/poll-judge", "schedule": "* * * * *" },
    { "path": "/api/cron/refresh-sku-affinity", "schedule": "0 4 * * *" },
    { "path": "/api/cron/poll-blog-jobs", "schedule": "* * * * *" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/properties/([^/]+)/status", "dest": "/api/properties/[id]/status?id=$1" },
    { "src": "/api/properties/([^/]+)/rerun", "dest": "/api/properties/[id]/rerun?id=$1" },
    { "src": "/api/properties/([^/]+)/archive", "dest": "/api/properties/[id]/archive?id=$1" },
    { "src": "/api/properties/([^/]+)/resume-checkout", "dest": "/api/properties/[id]/resume-checkout?id=$1" },
    { "src": "/api/properties/([^/]+)", "dest": "/api/properties/[id]?id=$1" },
    { "src": "/api/scenes/([^/]+)/approve", "dest": "/api/scenes/[id]/approve?id=$1" },
    { "src": "/api/scenes/([^/]+)/retry", "dest": "/api/scenes/[id]/retry?id=$1" },
    { "src": "/api/scenes/([^/]+)/skip", "dest": "/api/scenes/[id]/skip?id=$1" },
    { "src": "/api/scenes/([^/]+)/rate", "dest": "/api/scenes/[id]/rate?id=$1" },
    { "src": "/api/scenes/([^/]+)", "dest": "/api/scenes/[id]?id=$1" },
    { "src": "/api/pipeline/continue/([^/]+)", "dest": "/api/pipeline/continue/[runId]?runId=$1" },
    { "src": "/api/pipeline/([^/]+)", "dest": "/api/pipeline/[propertyId]?propertyId=$1" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/iterations/([^/]+)/rate", "dest": "/api/admin/prompt-lab/listings/[id]/iterations/[iterId]/rate?id=$1&iterId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/iterations/([^/]+)/chat/clear", "dest": "/api/admin/prompt-lab/listings/[id]/iterations/[iterId]/clear-chat?id=$1&iterId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/iterations/([^/]+)/chat", "dest": "/api/admin/prompt-lab/listings/[id]/iterations/[iterId]/chat?id=$1&iterId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/iterations/([^/]+)", "dest": "/api/admin/prompt-lab/listings/[id]/iterations/[iterId]?id=$1&iterId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/scenes/([^/]+)/pin-instruction", "dest": "/api/admin/prompt-lab/listings/[id]/scenes/[sceneId]/pin-instruction?id=$1&sceneId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/scenes/([^/]+)/chat/clear", "dest": "/api/admin/prompt-lab/listings/[id]/scenes/[sceneId]/clear-chat?id=$1&sceneId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/scenes/([^/]+)/chat", "dest": "/api/admin/prompt-lab/listings/[id]/scenes/[sceneId]/chat?id=$1&sceneId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/scenes/([^/]+)", "dest": "/api/admin/prompt-lab/listings/[id]/scenes/[sceneId]?id=$1&sceneId=$2" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/direct", "dest": "/api/admin/prompt-lab/listings/[id]/direct?id=$1" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)/render", "dest": "/api/admin/prompt-lab/listings/[id]/render?id=$1" },
    { "src": "/api/admin/prompt-lab/listings/([^/]+)", "dest": "/api/admin/prompt-lab/listings/[id]?id=$1" },
    { "src": "/api/admin/prompt-lab/listings", "dest": "/api/admin/prompt-lab/listings/index" },
    { "src": "/api/admin/prompt-lab/recipes", "dest": "/api/admin/prompt-lab/recipes" },
    { "src": "/api/admin/prompt-lab/mine", "dest": "/api/admin/prompt-lab/mine" },
    { "src": "/api/admin/prompt-lab/proposals", "dest": "/api/admin/prompt-lab/proposals" },
    { "src": "/api/admin/prompt-lab/rate", "dest": "/api/admin/prompt-lab/rate" },
    { "src": "/api/admin/prompt-lab/([^/]+)", "dest": "/api/admin/prompt-lab/[sessionId]?sessionId=$1" },
    { "src": "/api/blog/posts/([^/]+)/publish", "dest": "/api/blog/posts/[id]/publish?id=$1" },
    { "src": "/api/blog/posts/([^/]+)/reject", "dest": "/api/blog/posts/[id]/reject?id=$1" },
    { "src": "/api/blog/posts/([^/]+)/edit-on-sierra", "dest": "/api/blog/posts/[id]/edit-on-sierra?id=$1" },
    { "src": "/api/blog/posts/([^/]+)/hold", "dest": "/api/blog/posts/[id]/hold?id=$1" },
    { "src": "/api/blog/posts/([^/]+)", "dest": "/api/blog/posts/[id]?id=$1" },
    { "src": "/api/blog/images/([^/]+)", "dest": "/api/blog/images/[id]?id=$1" },
    { "src": "/api/blog/templates/([^/]+)", "dest": "/api/blog/templates/[id]?id=$1" },
    { "src": "/api/blog/email-templates/([^/]+)", "dest": "/api/blog/email-templates/[id]?id=$1" },
    { "src": "/api/blog/emails/([^/]+)/send", "dest": "/api/blog/emails/[id]/send?id=$1" },
    { "src": "/api/blog/emails/([^/]+)/test", "dest": "/api/blog/emails/[id]/test?id=$1" },
    { "src": "/api/blog/emails/([^/]+)", "dest": "/api/blog/emails/[id]?id=$1" },
    { "src": "/api/blog/market-update/runs/([^/]+)/generate", "dest": "/api/blog/market-update/runs/[id]/generate?id=$1" },
    { "src": "/api/blog/market-update/runs/([^/]+)", "dest": "/api/blog/market-update/runs/[id]?id=$1" },
    { "src": "/api/admin/studio/properties/([^/]+)/scenes/([^/]+)/swap-clip", "dest": "/api/admin/studio/properties/[id]/scenes/[idx]/swap-clip?id=$1&idx=$2" },
    { "src": "/api/admin/studio/properties/([^/]+)/preview-links/([^/]+)", "dest": "/api/admin/studio/properties/[id]/preview-links/[previewId]?id=$1&previewId=$2" },
    { "src": "/api/admin/studio/properties/([^/]+)/preview-links", "dest": "/api/admin/studio/properties/[id]/preview-links?id=$1" },
    { "src": "/api/admin/studio/properties/([^/]+)/preview-link", "dest": "/api/admin/studio/properties/[id]/preview-link?id=$1" },
    { "src": "/api/admin/studio/properties/([^/]+)/notes", "dest": "/api/admin/studio/properties/[id]/notes?id=$1" },
    { "src": "/api/admin/studio/properties/([^/]+)/download", "dest": "/api/admin/studio/properties/[id]/download?id=$1" },
    { "src": "/api/admin/studio/properties/([^/]+)", "dest": "/api/admin/studio/properties/[id]?id=$1" },
    { "src": "/api/admin/studio/delivery/([^/]+)", "dest": "/api/admin/studio/delivery/[runId]?runId=$1" },
    { "src": "/api/admin/studio/clients/([^/]+)", "dest": "/api/admin/studio/clients/[id]?id=$1" },
    { "src": "/api/admin/studio/creatives/renders", "dest": "/api/admin/studio/creatives/renders" },
    { "src": "/api/admin/studio/creatives/upload-url", "dest": "/api/admin/studio/creatives/upload-url" },
    { "src": "/api/admin/studio/creatives/bunny-upload", "dest": "/api/admin/studio/creatives/bunny-upload" },
    { "src": "/api/admin/studio/creatives/([^/]+)", "dest": "/api/admin/studio/creatives/[id]?id=$1" },
    { "src": "/api/admin/studio/video-folders/([^/]+)", "dest": "/api/admin/studio/video-folders/[id]?id=$1" },
    { "src": "/api/admin/studio/video-folders", "dest": "/api/admin/studio/video-folders/index" },
    { "src": "/api/admin/studio/videos/([^/]+)/library", "dest": "/api/admin/studio/videos/[id]/library?id=$1" },
    { "src": "/api/admin/studio/videos/([^/]+)", "dest": "/api/admin/studio/videos/[id]?id=$1" },
    { "src": "/api/admin/studio/videos", "dest": "/api/admin/studio/videos/index" },
    { "src": "/api/preview/([^/]+)/approve", "dest": "/api/preview/[token]/approve?token=$1" },
    { "src": "/api/preview/([^/]+)/download", "dest": "/api/preview/[token]/download?token=$1" },
    { "src": "/api/preview/([^/]+)/events", "dest": "/api/preview/[token]/events?token=$1" },
    { "src": "/api/preview/([^/]+)", "dest": "/api/preview/[token]?token=$1" },
    { "src": "/api/share/([^/]+)", "dest": "/api/share/[token]?token=$1" },
    { "src": "/api/account/(.*)", "dest": "/api/account/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/preview/([^/]+)/embed", "dest": "/index.html" },
    { "src": "/preview/([^/]+)", "dest": "/api/preview-page/[token]?token=$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
